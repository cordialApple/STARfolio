{
  "name": "superstar",
  "version": "0.1.0",
  "description": "STARfolio — private STAR accomplishment bank with AI practice",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "Brandon Randle",
  "homepage": ".",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "build:unpack": "npm run rebuild:electron && npm run build && electron-builder --dir",
    "build:win": "npm run rebuild:electron && npm run build && electron-builder --win",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "npm run build:unpack && playwright test",
    "test:e2e:dev": "npm run rebuild:electron && npm run build && playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/nunito": "^5.2.7",
    "@huggingface/transformers": "^4.2.0",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.24.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200",
    "smart-whisper": "^0.8.1",
    "sqlite-vec": "^0.1.9",
    "tailwind-merge": "^3.6.0",
    "turndown": "^7.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.2.0",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.13.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.brandonsuperstar.superstar",
    "productName": "STARfolio",
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "!**/.vscode/*",
      "!src/*",
      "!electron.vite.config.{js,ts,mjs,cjs}",
      "!{.eslintignore,.eslintrc.cjs,.prettierignore,.prettierrc.yaml,dev-app-update.yml,CHANGELOG.md,README.md}",
      "!{.env,.env.*,.npmrc,pnpm-lock.yaml}"
    ],
    "asarUnpack": [
      "resources/**",
      "node_modules/better-sqlite3/**",
      "node_modules/sqlite-vec/**",
      "node_modules/sqlite-vec-*/**",
      "node_modules/onnxruntime-node/**",
      "node_modules/@huggingface/transformers/**",
      "node_modules/sharp/**",
      "node_modules/@img/**",
      "node_modules/smart-whisper/**"
    ],
    "win": {
      "executableName": "STARfolio",
      "target": [
        {
          "target": "nsis",
          "arch": "x64"
        }
      ]
    },
    "nsis": {
      "artifactName": "${name}-${version}-setup.${ext}",
      "shortcutName": "${productName}",
      "uninstallDisplayName": "${productName}",
      "createDesktopShortcut": "always"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "cordialApple",
        "repo": "STARfolio"
      }
    ]
  }
}
